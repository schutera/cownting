# --- Cownting production secrets & settings ---
# Copy this file to `.env` and fill it in. `.env` is gitignored — never commit it.
#
#   cp .env.example .env

# Signing key for the login session cookie. Restarts stay logged in as long as
# this is stable. Generate one with:
#   openssl rand -hex 32
COWNTING_SECRET=

# Bootstrap admin account — created on FIRST boot only, when the user table is
# empty. Change the password after first login (or manage users in the Admin page).
COWNTING_ADMIN_USER=admin
COWNTING_ADMIN_PASSWORD=

# Public address Caddy serves on:
#   - a domain (e.g. cownting.example.com) -> automatic HTTPS via Let's Encrypt
#     (point the domain's DNS A/AAAA record at this server first)
#   - ":80"                                -> plain HTTP only (testing)
# When you use a real domain over HTTPS, also set `auth.https_only: true` in
# config/cownting.prod.yaml so the session cookie is HTTPS-only.
CADDY_SITE_ADDRESS=:80
